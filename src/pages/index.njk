{% set customHero = {
  hero: hero,
  height: "cover",
  content_inline: "left",
  region_space: "xl-2xl",
  button_variant: "blue"
} %}
{% include "partials/custom-hero.njk" %}


<div class="intro | wrapper">
  <article class="prose region flow feature">
    <h2>{{ intro.title | markdownInline | safe }}</h2>
      <div class="grid" data-layout="50-50">
          <div class="text-step-1">{{ intro.content_left | markdownFormat | safe }}</div>
          <div>{{ intro.content_right | markdownFormat | safe }}</div>
      </div>
  </article>
</div>

<div class="highlight-one | wrapper">
  <div class="full wrapper section" style="--spot-color: var(--color-blue-accent)">
    <article class="full  intro | section__inner wrapper  region">
      <div class="feature flow prose">
        <h2 class="text-step-3">{{ highlight_one.title }} <span>*</span></h2>
        <p class="text-step-min-1"><span>*</span> {{ highlight_one.subtitle }}</p>
      </div>
      {% svg "brand/waves" %}
    </article>
  </div>
</div>

<div class="highlight-two | wrapper">
  <div class="full wrapper section" style="--spot-color: var(--color-blue-accent-6)">
    <article class="full intro | section__inner wrapper region flow prose text-center text-blue-100">
      <h2 class="text-step-1 feature">
        {{ highlight_two.title1 }}
        <span class="block text-step-4 text-blue-400 mt-2xs">{{ highlight_two.title2 }} </span>
      </h2>
      <p class="flow-space-l">{{ highlight_two.content }}</p>
    </article>
  </div>
</div>

<div class="foundations | wrapper">
  <article class="full region flow">
    <h2 class="text-step-3 text-center">
      {{ foundations_titles.title1 }}
      <span class="block uppercase text-blue-500">{{ foundations_titles.title2 }} </span>
    </h2>
    <div class="split region">
      {% svg "brand/medusa-organic" %}
      <ol class="timeline">
        {% for key in foundations_elements %}
          <li>
            <span>{{ loop.index }}</span>
            <div class="flow flow-space-3xs">
              <h3 class="text-step-1">{{ key.title }}</h3>
              <p>{{ key.content }}</p>
            </div>
          </li>
        {% endfor %}
      </ol>
    </div>
  </article>
</div>

<div class="about | wrapper">
  <article class="feature | region">
    <header class="grid intro" data-layout="thirds">
      <h2>{{ about.title }}</h2>
      <div class="flow">{{ about.content | markdownFormat | safe }}</div>
    </header>
    {% set orderedTeamMembers = collections.team_members | sortByOrderIndex %}
    <div class="grid team mt-xl-2xl" data-layout="thirds">
      {% for member in orderedTeamMembers %}
      {% if member.data.show_on_about %}
        <custom-card clickable small-padding img-3-2>
          {% image "." + member.data.image, "" %}
          <h3 class="text-step-1" slot="headline"><a href="{{ member.url }}">{{ member.data.name }}</a>  {% if member.data.role %}
              <span class="text-step-min-1 font-bold">{{ member.data.role }}</span>
            {% endif %}</h3>
          <div slot="content" webc:nokeep>
            {{ member.data.description_short | markdownFormat | safe }}
          </div>
        </custom-card>
      {% endif %}
      {% endfor %}
    </div>
  </article>
</div>

<div class="why | wrapper">
  <article class="feature | region flow">
    <header class="flow">
    <h2 class="heading-line">{{ whyus_intro.title }}</h2>
      {{ whyus_intro.content | markdownFormat | safe }}
      </header>

      <dl class="flow region column" role="list">
        {% for key in whyus_elements %}
          <div class="flow">
            <dt class="font-bold text-purple">{{ key.title }}</dt>
            <dd>{{ key.content }}</dd>
          </div>
        {% endfor %}
      </dl>
  </article>
</div>

<div class="services | wrapper">

  {% if our_services.image %}
  {% image our_services.image, "" %}
  {% endif %}

    <article class="wrapper region flow">
        <h2 class="text-center">{{ our_services.title }}</h2>

          {% for item in our_services_items %}

            <div class="grid" data-layout="thirds">
              <h3>{{ item.prefix }} <span>{{ item.title }}</span></h3>
              <div>
              {{ item.description | markdownFormat | safe }}
            </div>
            </div>

          {% endfor %}
    </article>

</div>

<div class="blog | wrapper">
  <section class="full | region">
    <div class="wrapper flow prose">
      <h2><a class="no-underline hover:underline" href="/insights/">{{ blog.title }}</a></h2>

      {% if blog.intro %}
        <p>{{ blog.intro }}</p>
      {% endif %}

      <div class="feature">
        <div class="grid gutter-s" data-layout='thirds'>

         {% set itemList = collections.allPosts %}
         {% asyncEach item in itemList.slice(0, 3) %}
         {% set showTags = false %}
         {% set headingLevel = "h3" %}
           {% include "partials/card-blog.njk" %}
         {% endeach %}

        </div>
      </div>
    </div>
  </section>
</div>

{%- css "local" -%}
  {%- include "css/custom-hero.css" -%}
  {%- include 'css/home.css' -%}
  {%- include 'css/column.css' -%}
  {%- include "css/custom-card.css" -%}
{%- endcss -%}
